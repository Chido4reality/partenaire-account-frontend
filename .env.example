# Mon Partenaire frontend — local dev env template.
# Copy to .env and point at whatever backend you're running against.
#
#   - Local Express backend (npm run dev in ../backend on port 3001):
#       VITE_API_URL=http://localhost:3001/api
#   - Render-deployed backend (no local backend needed):
#       VITE_API_URL=https://your-backend.onrender.com/api
#
# .env is gitignored; do not commit your local values.
VITE_API_URL=https://your-backend.onrender.com/api
